{
  "name": "music-app-root",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "bash -c 'cd frontend && npx eslint --fix'",
      "bash -c 'cd frontend && npx tsc --noEmit'"
    ],
    "backend/**/*.js": [
      "echo 'Backend JS linting skipped (no ESLint configured)'"
    ]
  }
}
